{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://afscp.internal/schemas/afscp-internal-v1.schema.json",
  "title": "AFSCP Internal API V1 Schemas",
  "type": "object",
  "$defs": {
    "Actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "system", "admin_job", "migration_job", "operator"]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      }
    },
    "NamespaceId": {
      "type": "string",
      "pattern": "^ns_[A-Za-z0-9][A-Za-z0-9_-]{1,62}$"
    },
    "VolumeId": {
      "type": "string",
      "pattern": "^vol_[A-Za-z0-9][A-Za-z0-9_-]{1,62}$"
    },
    "RepoId": {
      "type": "string",
      "pattern": "^repo_[A-Za-z0-9][A-Za-z0-9_-]{1,62}$"
    },
    "TemplateId": {
      "type": "string",
      "pattern": "^tmpl_[A-Za-z0-9][A-Za-z0-9_-]{1,62}$"
    },
    "ExportId": {
      "type": "string",
      "pattern": "^export_[A-Za-z0-9][A-Za-z0-9_-]{1,62}$"
    },
    "WorkloadMountBindingId": {
      "type": "string",
      "pattern": "^wmb_[A-Za-z0-9][A-Za-z0-9_-]{1,62}$"
    },
    "OperationId": {
      "type": "string",
      "pattern": "^op_[A-Za-z0-9][A-Za-z0-9_-]{1,62}$"
    },
    "SavePointId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
    },
    "JvsRepoId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$"
    },
    "MountPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^/(?!.*(?:^|/)\\.\\.(?:/|$))(?!proc(?:/|$))(?!sys(?:/|$))(?!dev(?:/|$))(?!var/run/secrets(?:/|$))(?!run/secrets(?:/|$)).*$"
    },
    "PayloadVolumeSubdir": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^afscp/(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./-]+/payload$"
    },
    "ResourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "volume",
            "namespace",
            "repo",
            "repo_template",
            "export",
            "workload_mount_binding",
            "operation"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "ErrorCode": {
      "type": "string",
      "enum": [
        "AUTHENTICATION_FAILED",
        "CALLER_NOT_ALLOWED",
        "ROLE_NOT_ALLOWED",
        "NAMESPACE_NOT_FOUND",
        "NAMESPACE_DISABLED",
        "RESOURCE_NAMESPACE_MISMATCH",
        "INVALID_ID",
        "PATH_DENIED",
        "CAPABILITY_DENIED",
        "IDEMPOTENCY_CONFLICT",
        "REPO_ALREADY_EXISTS",
        "REPO_NOT_FOUND",
        "VOLUME_NOT_FOUND",
        "OPERATION_NOT_FOUND",
        "STORAGE_UNAVAILABLE",
        "INTERNAL_ERROR",
        "REPO_JVS_MUTATION_IN_PROGRESS",
        "ACTIVE_WRITER_SESSIONS",
        "WRITER_SESSION_FENCE_HELD",
        "STALE_WRITER_SESSION_UNCERTAIN",
        "RESTORE_DIRTY_STATE",
        "RESTORE_PREVIEW_STALE",
        "RESTORE_CONFIRMATION_REQUIRED",
        "JVS_COMMAND_FAILED",
        "JVS_DOCTOR_FAILED",
        "SOURCE_DIRTY_AFTER_TEMPLATE_SAVE",
        "VOLUME_MISMATCH_REQUIRES_IMPORT",
        "EXPORT_EXPIRED",
        "EXPORT_REVOKED",
        "MOUNT_BINDING_TERMINAL",
        "REPO_LIFECYCLE_INVALID_STATE",
        "REPO_LIFECYCLE_FENCE_HELD",
        "ACTIVE_SESSIONS_BLOCK_LIFECYCLE",
        "STALE_SESSION_BLOCKS_LIFECYCLE",
        "REPO_ARCHIVED",
        "REPO_TOMBSTONED",
        "REPO_PURGED",
        "PURGE_CONFIRMATION_REQUIRED",
        "PURGE_RETENTION_NOT_MET",
        "PURGE_REQUIRES_OPERATOR_APPROVAL",
        "OPERATION_RECOVERY_REQUIRED",
        "RESTORE_RECONCILIATION_ACTIVE"
      ]
    },
    "StandardError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "retryable", "correlation_id"],
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string", "minLength": 1 },
        "retryable": { "type": "boolean" },
        "correlation_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "operation_id": { "type": ["string", "null"], "maxLength": 128 },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "ErrorEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error"],
      "properties": {
        "error": { "$ref": "#/$defs/StandardError" }
      }
    },
    "OperationState": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "cancel_requested",
        "cancelled",
        "operator_intervention_required"
      ]
    },
    "OperationType": {
      "type": "string",
      "enum": [
        "volume_ensure",
        "namespace_upsert",
        "namespace_disable",
        "namespace_volume_binding_put",
        "repo_create",
        "repo_archive",
        "repo_restore_archived",
        "repo_delete",
        "repo_restore_tombstoned",
        "repo_purge",
        "save_point_create",
        "restore",
        "restore_preview",
        "restore_preview_discard",
        "restore_run",
        "template_create",
        "template_clone",
        "export_create",
        "export_revoke",
        "export_session_reconcile",
        "mount_binding_create",
        "mount_binding_status_update",
        "mount_binding_heartbeat",
        "mount_binding_release",
        "mount_binding_revoke",
        "migration_cutover"
      ]
    },
    "OperationEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "operation_state", "resource", "result", "error"],
      "properties": {
        "operation_id": { "$ref": "#/$defs/OperationId" },
        "operation_state": { "$ref": "#/$defs/OperationState" },
        "resource": { "$ref": "#/$defs/ResourceRef" },
        "result": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "error": {
          "oneOf": [
            { "$ref": "#/$defs/StandardError" },
            { "type": "null" }
          ]
        }
      }
    },
    "OperationRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation_id",
        "operation_type",
        "operation_state",
        "phase",
        "attempt",
        "lease_owner",
        "lease_expires_at",
        "idempotency_scope",
        "idempotency_key",
        "request_hash",
        "correlation_id",
        "caller_service",
        "authorized_actor",
        "resource",
        "namespace_id",
        "repo_id",
        "template_id",
        "export_id",
        "mount_binding_id",
        "session_fence_id",
        "external_resource_ids",
        "input_summary",
        "jvs_json_output",
        "verification_result",
        "compensation_status",
        "error",
        "created_at",
        "started_at",
        "finished_at"
      ],
      "properties": {
        "operation_id": { "$ref": "#/$defs/OperationId" },
        "operation_type": { "$ref": "#/$defs/OperationType" },
        "operation_state": { "$ref": "#/$defs/OperationState" },
        "phase": { "type": "string", "minLength": 1, "maxLength": 128 },
        "attempt": { "type": "integer", "minimum": 0 },
        "lease_owner": { "type": ["string", "null"], "maxLength": 256 },
        "lease_expires_at": { "type": ["string", "null"], "format": "date-time" },
        "idempotency_scope": { "type": "string", "minLength": 1, "maxLength": 512 },
        "idempotency_key": { "type": "string", "minLength": 1, "maxLength": 256 },
        "request_hash": { "type": "string", "minLength": 1, "maxLength": 256 },
        "correlation_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "caller_service": { "type": "string", "minLength": 1, "maxLength": 256 },
        "authorized_actor": { "$ref": "#/$defs/Actor" },
        "resource": { "$ref": "#/$defs/ResourceRef" },
        "namespace_id": {
          "oneOf": [{ "$ref": "#/$defs/NamespaceId" }, { "type": "null" }]
        },
        "repo_id": {
          "oneOf": [{ "$ref": "#/$defs/RepoId" }, { "type": "null" }]
        },
        "template_id": {
          "oneOf": [{ "$ref": "#/$defs/TemplateId" }, { "type": "null" }]
        },
        "export_id": {
          "oneOf": [{ "$ref": "#/$defs/ExportId" }, { "type": "null" }]
        },
        "mount_binding_id": {
          "oneOf": [{ "$ref": "#/$defs/WorkloadMountBindingId" }, { "type": "null" }]
        },
        "session_fence_id": { "type": ["string", "null"], "maxLength": 128 },
        "external_resource_ids": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "input_summary": {
          "type": "object",
          "additionalProperties": true
        },
        "jvs_json_output": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "verification_result": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "compensation_status": { "type": ["string", "null"], "maxLength": 128 },
        "error": {
          "oneOf": [
            { "$ref": "#/$defs/StandardError" },
            { "type": "null" }
          ]
        },
        "created_at": { "type": "string", "format": "date-time" },
        "started_at": { "type": ["string", "null"], "format": "date-time" },
        "finished_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "OperatorRepairAction": {
      "type": "string",
      "enum": ["terminalize_unsupported_intervention_as_failed"]
    },
    "OperatorRepairRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "reason", "evidence_ref", "affected_ids"],
      "properties": {
        "action": { "$ref": "#/$defs/OperatorRepairAction" },
        "reason": { "type": "string", "minLength": 1, "maxLength": 512 },
        "evidence_ref": { "type": "string", "minLength": 1, "maxLength": 512 },
        "affected_ids": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        }
      }
    },
    "OperatorRepairStateSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": { "$ref": "#/$defs/OperationState" },
        "phase": { "type": "string", "maxLength": 128 }
      }
    },
    "OperatorRepairResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "operation_id", "before", "after", "repair_outcome", "reason", "evidence_ref", "affected_ids"],
      "properties": {
        "action": { "$ref": "#/$defs/OperatorRepairAction" },
        "operation_id": { "$ref": "#/$defs/OperationId" },
        "before": { "$ref": "#/$defs/OperatorRepairStateSnapshot" },
        "after": { "$ref": "#/$defs/OperatorRepairStateSnapshot" },
        "audit_event_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "repair_outcome": {
          "type": "string",
          "enum": ["terminalized_failed", "already_terminal"]
        },
        "reason": { "type": "string", "minLength": 1, "maxLength": 512 },
        "evidence_ref": { "type": "string", "minLength": 1, "maxLength": 512 },
        "affected_ids": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "operation": { "$ref": "#/$defs/OperationRecord" }
      }
    },
    "Namespace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace_id", "status", "created_at"],
      "properties": {
        "namespace_id": { "$ref": "#/$defs/NamespaceId" },
        "status": { "type": "string", "enum": ["active", "disabled"] },
        "disabled_reason": { "type": ["string", "null"], "maxLength": 1024 },
        "created_at": { "type": "string", "format": "date-time" },
        "disabled_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "UpsertNamespaceRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace_id"],
      "properties": {
        "namespace_id": { "$ref": "#/$defs/NamespaceId" }
      }
    },
    "DisableNamespaceRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason"],
      "properties": {
        "reason": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },
    "VolumeHealthFindingCode": {
      "type": "string",
      "enum": [
        "VOLUME_DISABLED",
        "VOLUME_DEGRADED",
        "CAPABILITY_NOT_READY",
        "BACKEND_PROBE_MISSING",
        "BACKEND_PROBE_FAILED",
        "BACKEND_PROBE_ERROR"
      ]
    },
    "VolumeHealth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["volume_id", "status", "checked_at", "findings"],
      "properties": {
        "volume_id": { "$ref": "#/$defs/VolumeId" },
        "status": { "type": "string", "enum": ["healthy", "degraded", "unavailable"] },
        "checked_at": { "type": "string", "format": "date-time" },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "message", "severity"],
            "properties": {
              "code": { "$ref": "#/$defs/VolumeHealthFindingCode" },
              "message": { "type": "string", "minLength": 1, "maxLength": 1024 },
              "severity": { "type": "string", "enum": ["info", "warning", "critical"] }
            }
          }
        }
      }
    },
    "Volume": {
      "type": "object",
      "additionalProperties": false,
      "required": ["volume_id", "backend", "isolation_class", "status", "capabilities"],
      "properties": {
        "volume_id": { "$ref": "#/$defs/VolumeId" },
        "backend": { "type": "string", "enum": ["juicefs"] },
        "isolation_class": { "type": "string", "enum": ["shared", "dedicated"] },
        "status": { "type": "string", "enum": ["active", "disabled", "degraded"] },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "required": ["webdav_export", "workload_mount", "jvs_external_control_root", "directory_quota"],
          "properties": {
            "webdav_export": { "type": "boolean" },
            "workload_mount": { "type": "boolean" },
            "jvs_external_control_root": { "type": "boolean" },
            "filtered_mount": { "type": "boolean" },
            "directory_quota": {
              "type": "boolean",
              "description": "directory_quota is the selected volume capability that can support directory quota enforcement. quota_bytes_default remains a namespace binding policy record and enforcement hook, and is not enforced unless the selected volume capability supports directory quota enforcement and the integration enables it."
            },
            "csi_driver": { "type": "string" },
            "storage_class": { "type": "string" },
            "permission_model": { "type": "string" }
          }
        }
      }
    },
    "CallerRole": {
      "type": "string",
      "enum": [
        "volume_admin",
        "namespace_admin",
        "repo_admin",
        "repo_lifecycle_admin",
        "restore_admin",
        "template_admin",
        "export_admin",
        "mount_admin",
        "operation_inspector",
        "orchestrator_mount",
        "migration_admin",
        "operator_admin",
        "break_glass_admin"
      ]
    },
    "NamespaceBindingCallerRole": {
      "type": "string",
      "enum": [
        "namespace_admin",
        "repo_admin",
        "repo_lifecycle_admin",
        "restore_admin",
        "template_admin",
        "export_admin",
        "mount_admin",
        "operation_inspector",
        "orchestrator_mount",
        "migration_admin"
      ]
    },
    "AllowedCaller": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caller_service", "roles"],
      "properties": {
        "caller_service": { "type": "string", "minLength": 1, "maxLength": 256 },
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/NamespaceBindingCallerRole" }
        }
      }
    },
    "NamespaceVolumeBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "namespace_id",
        "default_volume_id",
        "allowed_callers",
        "quota_bytes_default",
        "export_policy",
        "lifecycle_policy",
        "mount_policy",
        "template_policy",
        "status"
      ],
      "properties": {
        "namespace_id": { "$ref": "#/$defs/NamespaceId" },
        "default_volume_id": { "$ref": "#/$defs/VolumeId" },
        "allowed_callers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/AllowedCaller" }
        },
        "quota_bytes_default": {
          "type": "integer",
          "minimum": 0,
          "description": "quota_bytes_default is a namespace binding policy record and enforcement hook. It is not enforced as a capacity limit unless the selected volume capability directory_quota supports directory quota enforcement and the integration enables it."
        },
        "export_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["webdav_enabled", "max_session_seconds"],
          "properties": {
            "webdav_enabled": { "type": "boolean" },
            "max_session_seconds": { "type": "integer", "minimum": 60 }
          }
        },
        "lifecycle_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tombstone_retention_seconds",
            "purge_requires_lifecycle_admin",
            "break_glass_purge_enabled"
          ],
          "properties": {
            "tombstone_retention_seconds": { "type": "integer", "minimum": 0 },
            "purge_requires_lifecycle_admin": { "type": "boolean" },
            "break_glass_purge_enabled": { "type": "boolean" }
          }
        },
        "mount_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "workload_mount_enabled",
            "workload_mount_requires_external_control_root",
            "allow_privileged_workload"
          ],
          "properties": {
            "workload_mount_enabled": { "type": "boolean" },
            "workload_mount_requires_external_control_root": { "type": "boolean" },
            "allow_privileged_workload": { "type": "boolean" }
          }
        },
        "template_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["namespace_templates_enabled", "cross_namespace_clone_enabled"],
          "properties": {
            "namespace_templates_enabled": { "type": "boolean" },
            "cross_namespace_clone_enabled": { "type": "boolean" }
          }
        },
        "status": { "type": "string", "enum": ["active", "disabled"] }
      }
    },
    "RepoLifecycleStatus": {
      "type": "string",
      "enum": [
        "active",
        "archiving",
        "archived",
        "restoring_archived",
        "deleting",
        "tombstoned",
        "restoring_tombstoned",
        "purging",
        "purged",
        "operator_intervention_required"
      ]
    },
    "Repo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_id",
        "namespace_id",
        "volume_id",
        "repo_kind",
        "jvs_repo_id",
        "status",
        "lifecycle",
        "created_at"
      ],
      "properties": {
        "repo_id": { "$ref": "#/$defs/RepoId" },
        "namespace_id": { "$ref": "#/$defs/NamespaceId" },
        "volume_id": { "$ref": "#/$defs/VolumeId" },
        "repo_kind": { "type": "string", "enum": ["repo", "template"] },
        "jvs_repo_id": { "$ref": "#/$defs/JvsRepoId" },
        "status": { "$ref": "#/$defs/RepoLifecycleStatus" },
        "lifecycle": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "retention_expires_at", "last_lifecycle_operation_id"],
          "properties": {
            "status": { "$ref": "#/$defs/RepoLifecycleStatus" },
            "retention_expires_at": { "type": ["string", "null"], "format": "date-time" },
            "last_lifecycle_operation_id": { "type": ["string", "null"], "maxLength": 128 },
            "pre_delete_status": { "$ref": "#/$defs/RepoLifecycleStatus" }
          }
        },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "CreateRepoRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace_id", "target_repo_id"],
      "properties": {
        "namespace_id": { "$ref": "#/$defs/NamespaceId" },
        "target_repo_id": { "$ref": "#/$defs/RepoId" }
      }
    },
    "LifecycleRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reason": { "type": "string", "maxLength": 1024 }
      }
    },
    "PurgeRepoRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "product_confirmation_ref"],
      "properties": {
        "reason": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "product_confirmation_ref": { "type": "string", "minLength": 1, "maxLength": 256 },
        "retention_override_requested": { "type": "boolean", "default": false },
        "operator_approval_ref": { "type": "string", "maxLength": 256 }
      }
    },
    "SavePoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["save_point_id", "repo_id", "created_at"],
      "properties": {
        "save_point_id": { "$ref": "#/$defs/SavePointId" },
        "repo_id": { "$ref": "#/$defs/RepoId" },
        "message": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "CreateSavePointRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message"],
      "properties": {
        "message": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    },
    "RestorePreviewRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["save_point_id"],
      "properties": {
        "save_point_id": { "$ref": "#/$defs/SavePointId" }
      }
    },
    "RestoreRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["save_point_id", "discard_unsaved_changes_confirmed"],
      "properties": {
        "save_point_id": { "$ref": "#/$defs/SavePointId" },
        "discard_unsaved_changes_confirmed": { "type": "boolean", "const": true }
      }
    },
    "RestoreRunRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preview_operation_id"],
      "properties": {
        "preview_operation_id": { "$ref": "#/$defs/OperationId" }
      }
    },
    "RestorePreviewDiscardRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preview_operation_id"],
      "properties": {
        "preview_operation_id": { "$ref": "#/$defs/OperationId" }
      }
    },
    "RepoTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["template_id", "namespace_id", "volume_id", "source_repo_id", "status", "created_at"],
      "properties": {
        "template_id": { "$ref": "#/$defs/TemplateId" },
        "namespace_id": { "$ref": "#/$defs/NamespaceId" },
        "volume_id": { "$ref": "#/$defs/VolumeId" },
        "source_repo_id": { "$ref": "#/$defs/RepoId" },
        "source_save_point_id": { "$ref": "#/$defs/SavePointId" },
        "status": { "type": "string", "enum": ["creating", "published", "failed"] },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "CreateRepoTemplateRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace_id", "source_repo_id", "target_template_id", "clone_history_mode"],
      "properties": {
        "namespace_id": { "$ref": "#/$defs/NamespaceId" },
        "source_repo_id": { "$ref": "#/$defs/RepoId" },
        "target_template_id": { "$ref": "#/$defs/TemplateId" },
        "clone_history_mode": { "type": "string", "enum": ["main"] }
      }
    },
    "CloneRepoTemplateRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace_id", "template_id", "target_repo_id"],
      "properties": {
        "namespace_id": { "$ref": "#/$defs/NamespaceId" },
        "template_id": { "$ref": "#/$defs/TemplateId" },
        "target_repo_id": { "$ref": "#/$defs/RepoId" }
      }
    },
    "ExportSession": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export_id",
        "namespace_id",
        "repo_id",
        "protocol",
        "mode",
        "status",
        "created_by_caller_service",
        "created_by_actor",
        "created_at",
        "updated_at",
        "expires_at",
        "revoked_at",
        "last_accessed_at",
        "active_request_count",
        "active_write_count",
        "last_observed_at",
        "last_gateway_heartbeat_at",
        "gateway_heartbeat_expires_at",
        "write_drained_at",
        "terminal_observed_at",
        "status_reason"
      ],
      "properties": {
        "export_id": { "$ref": "#/$defs/ExportId" },
        "namespace_id": { "$ref": "#/$defs/NamespaceId" },
        "repo_id": { "$ref": "#/$defs/RepoId" },
        "protocol": { "type": "string", "enum": ["webdav"] },
        "mode": { "type": "string", "enum": ["read_only", "read_write"] },
        "status": { "type": "string", "enum": ["active", "revoking", "revoked", "expired", "failed"] },
        "created_by_caller_service": { "type": "string", "minLength": 1, "maxLength": 256 },
        "created_by_actor": { "$ref": "#/$defs/Actor" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "revoked_at": { "type": ["string", "null"], "format": "date-time" },
        "last_accessed_at": { "type": ["string", "null"], "format": "date-time" },
        "active_request_count": { "type": "integer", "minimum": 0 },
        "active_write_count": { "type": "integer", "minimum": 0 },
        "last_observed_at": { "type": ["string", "null"], "format": "date-time" },
        "last_gateway_heartbeat_at": { "type": ["string", "null"], "format": "date-time" },
        "gateway_heartbeat_expires_at": { "type": ["string", "null"], "format": "date-time" },
        "write_drained_at": { "type": ["string", "null"], "format": "date-time" },
        "terminal_observed_at": { "type": ["string", "null"], "format": "date-time" },
        "status_reason": { "type": "string", "maxLength": 1024 }
      }
    },
    "ExportAccessCredential": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "auth", "mode", "expires_at"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "username", "password"],
          "properties": {
            "type": { "type": "string", "enum": ["basic"] },
            "username": { "type": "string", "minLength": 1, "maxLength": 256 },
            "password": { "type": "string", "minLength": 1, "maxLength": 512 }
          }
        },
        "mode": { "type": "string", "enum": ["read_only", "read_write"] },
        "expires_at": { "type": "string", "format": "date-time" }
      }
    },
    "ExportCreateResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["export"],
      "properties": {
        "export": { "$ref": "#/$defs/ExportSession" },
        "access": { "$ref": "#/$defs/ExportAccessCredential" }
      }
    },
    "ExportCreateOperationEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "operation_state", "resource", "result", "error"],
      "properties": {
        "operation_id": { "$ref": "#/$defs/OperationId" },
        "operation_state": { "$ref": "#/$defs/OperationState" },
        "resource": { "$ref": "#/$defs/ResourceRef" },
        "result": { "$ref": "#/$defs/ExportCreateResult" },
        "error": {
          "oneOf": [
            { "$ref": "#/$defs/StandardError" },
            { "type": "null" }
          ]
        }
      }
    },
    "CreateExportRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["read_only", "read_write"] },
        "ttl_seconds": { "type": "integer", "minimum": 60 }
      }
    },
    "WorkloadMountBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mount_binding_id", "namespace_id", "repo_id", "volume_id", "mount_path", "read_only", "status", "lease_expires_at"],
      "properties": {
        "mount_binding_id": { "$ref": "#/$defs/WorkloadMountBindingId" },
        "namespace_id": { "$ref": "#/$defs/NamespaceId" },
        "repo_id": { "$ref": "#/$defs/RepoId" },
        "volume_id": { "$ref": "#/$defs/VolumeId" },
        "mount_path": { "$ref": "#/$defs/MountPath" },
        "read_only": { "type": "boolean" },
        "status": { "type": "string", "enum": ["issued", "pending", "active", "releasing", "released", "revoked", "expired", "failed"] },
        "lease_expires_at": { "type": "string", "format": "date-time" }
      }
    },
    "CreateWorkloadMountBindingRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mount_path", "read_only", "lease_seconds"],
      "properties": {
        "mount_path": { "$ref": "#/$defs/MountPath" },
        "read_only": { "type": "boolean" },
        "lease_seconds": { "type": "integer", "minimum": 60 }
      }
    },
    "MountBindingStatusUpdateRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "observed_at"],
      "properties": {
        "status": { "type": "string", "enum": ["pending", "active", "released", "revoked", "expired", "failed"] },
        "observed_at": { "type": "string", "format": "date-time" },
        "lease_expires_at": { "type": ["string", "null"], "format": "date-time" },
        "reason": { "type": "string", "maxLength": 1024 }
      }
    },
    "OrchestratorMountPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mount_binding_id", "volume_id", "payload_volume_subdir", "mount_path", "read_only", "secret_ref", "security_policy"],
      "properties": {
        "mount_binding_id": { "$ref": "#/$defs/WorkloadMountBindingId" },
        "volume_id": { "$ref": "#/$defs/VolumeId" },
        "payload_volume_subdir": { "$ref": "#/$defs/PayloadVolumeSubdir" },
        "mount_path": { "$ref": "#/$defs/MountPath" },
        "read_only": { "type": "boolean" },
        "secret_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": ["namespace", "name"],
          "properties": {
            "namespace": { "type": "string" },
            "name": { "type": "string" }
          }
        },
        "security_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["run_as_non_root", "allow_privileged", "jvs_control_outside_payload"],
          "properties": {
            "run_as_non_root": { "type": "boolean" },
            "allow_privileged": { "type": "boolean" },
            "drop_capabilities": {
              "type": "array",
              "items": { "type": "string" }
            },
            "jvs_control_outside_payload": { "type": "boolean" }
          }
        }
      }
    }
  }
}
